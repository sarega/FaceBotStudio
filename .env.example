# OpenRouter API key (server-side only, do not expose in frontend)
OPENROUTER_API_KEY="API_KEY_HERE"

# Facebook Page access token (required for auto-reply on Messenger)
PAGE_ACCESS_TOKEN=""

# Facebook App Secret (recommended for webhook signature verification)
FACEBOOK_APP_SECRET=""

# Optional Graph API version for send-message endpoint
FACEBOOK_GRAPH_API_VERSION="v22.0"

# Default model used if no model is selected in settings
OPENROUTER_DEFAULT_MODEL="google/gemini-3-flash-preview"

# Embedding model used for queued document vectors and retrieval
OPENROUTER_EMBEDDING_MODEL="text-embedding-3-small"

# Optional webhook URL that receives a copy of document embedding payload jobs
EMBEDDING_HOOK_URL=""

# Public app URL (used for webhook callback display and OpenRouter headers)
APP_URL="http://localhost:3000"

# Session cookie lifetime in days
SESSION_TTL_DAYS="14"

# Scoped check-in access session lifetime in minutes (5-1440)
CHECKIN_ACCESS_SESSION_TTL_MINUTES="120"

# Max JSON body size for API requests (Express format, e.g. 256kb / 1mb)
JSON_BODY_LIMIT="256kb"

# Optional comma-separated extra origins allowed by CSRF origin check
CSRF_ALLOWED_ORIGINS=""

# Express trust proxy setting (recommended: "1" behind one reverse proxy; use "false" if direct)
TRUST_PROXY=""

# Runtime mode: all | web | worker
APP_RUNTIME="all"

# Optional deploy port (most platforms inject this automatically)
PORT="3000"

# Redis connection (used for queue, dedup, and rate limiting)
REDIS_URL=""

# SQLite DB file path (for Railway volume use something like /data/bot.db)
DB_PATH="bot.db"

# Public upload storage root (for Railway volume use something like /data/uploads)
PUBLIC_UPLOADS_DIR=""
